# Copy to deploy/matcher.env and fill in. Never commit the filled file (gitignored via *.env).
#   cp deploy/matcher.env.example deploy/matcher.env
#   docker compose --env-file deploy/matcher.env up -d --build

# Public domain for the matcher. Needs a DNS A/AAAA record pointing at this host.
MATCHER_DOMAIN=matcher.example.com

# Allowed browser origin (your deployed frontend). Use "*" only for quick tests.
CORS_ORIGIN=https://your-frontend.vercel.app

# Funded Stellar TESTNET secret ("S…") — the matcher's hot key that pays tx fees.
# Generate + fund:  stellar keys generate matcher --network testnet --fund
#                   stellar keys secret matcher        # prints the S… value
LAX_STELL_MATCHER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Soroban RPC (default is fine for testnet).
LAX_STELL_RPC_URL=https://soroban-testnet.stellar.org

# Match loop cadence in ms (optional).
MATCH_INTERVAL_MS=2000
