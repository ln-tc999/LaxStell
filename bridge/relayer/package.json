{
  "name": "@lax-stell/relayer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LaxStell bridge relayer — UNTRUSTED transport that feeds Ethereum data to the Soroban contracts: beacon LightClientFinalityUpdate -> EthLightClient.update_header (with off-chain BLS12-381 decompression), and eth_getProof -> LaxStellBridge.bridge_in. Holds no authority; every value is re-verified on-chain.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lax-stell-relayer": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/curves": "1.9.7",
    "@stellar/stellar-sdk": "^14.6.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
